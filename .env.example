DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# 빠른 테스트용 길드 명령 등록. 비워두면 전역 명령으로 등록됩니다.
DISCORD_GUILD_ID=

# Discord Developer Portal에서 Message Content Intent를 켠 경우에만 true로 바꾸세요.
# false이면 Render의 "Used disallowed intents" 오류를 피하고 슬래시 명령 중심으로 실행됩니다.
DISCORD_MESSAGE_CONTENT_INTENT=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Message Content Intent가 true일 때 공개 채널 자연 대화에 사용됩니다.
BOT_REPLY_CHANNEL_IDS=
BOT_TRIGGER_KEYWORDS=세냥,세냥장,냥포인트
BOT_PROACTIVE_REPLY_CHANCE=0.01
BOT_PERSONALITY_BLOCK_CHANCE=0.001
BOT_PROACTIVE_COOLDOWN_MINUTES=10
BOT_PERSONALITY_BLOCK_COOLDOWN_MINUTES=360

STARTING_POINTS=100
BET_STAKE=10
